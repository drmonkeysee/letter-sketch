{
  "name": "letter-sketch",
  "version": "1.0.0",
  "description": "An ASCII sketch program",
  "browserslist": [
    "defaults"
  ],
  "scripts": {
    "start": "parcel index.html",
    "test": "mocha",
    "lint": "eslint src test",
    "lint:fix": "eslint --fix src test",
    "clean": "rm -rf .parcel-cache dist",
    "scrub": "npm run clean && rm -r node_modules",
    "build": "parcel build index.html",
    "web-publish": "sh publish.sh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/drmonkeysee/letter-sketch.git"
  },
  "author": {
    "name": "Brandon Stansbury",
    "email": "brandonrstansbury@gmail.com",
    "url": "https://github.com/drmonkeysee"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/drmonkeysee/letter-sketch/issues"
  },
  "homepage": "https://github.com/drmonkeysee/letter-sketch#readme",
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/register": "^7.28.6",
    "@eslint/js": "^10.0.1",
    "@parcel/transformer-sass": "^2.16.4",
    "chai": "^6.2.2",
    "core-js": "^3.49.0",
    "eslint": "^10.4.1",
    "eslint-plugin-mocha": "^11.3.0",
    "mocha": "^11.7.5",
    "parcel": "^2.16.4",
    "sinon": "^21.1.2"
  },
  "engines": {
    "node": ">=22"
  },
  "private": true
